# Copy to .env and fill in.

# Public hostname of your app; must have a DNS A record pointing at this host.
APP_DOMAIN=app.example.com

# Email shown in the Let's Encrypt cert and used for expiry notices.
ACME_EMAIL=admin@example.com

# --- yandex-iap ---

# From https://oauth.yandex.ru/client/new
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

CALLBACK_URL=https://app.example.com/auth/callback

# .example.com for multi-subdomain SSO, or app.example.com to restrict the cookie.
COOKIE_DOMAIN=.example.com

# Generate once: openssl rand -base64 32
COOKIE_SECRET=change-me-to-a-32+-character-random-string

WHITELIST_FILE=/etc/iap/allowed-emails.txt
COOKIE_TTL=24h
SKIP_AUTH_REGEX=^/(healthz|api/health)$
LOG_LEVEL=info
